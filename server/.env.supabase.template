# Supabase Configuration
# 复制此文件为 .env.supabase 并填入你的 Supabase 项目信息

# Supabase Database URL
# 在 Supabase Dashboard > Settings > Database 中找到
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# JWT Configuration
# 在 Supabase Dashboard > Settings > API 中找到 JWT Secret
JWT_SECRET="your-super-secret-jwt-key-from-supabase"

# Token Expiration
JWT_EXPIRATION="7d"

# Supabase Project Reference
# 在 Supabase Dashboard > Settings > General 中找到
SUPABASE_PROJECT_REF="your-project-ref"

# Supabase Anon Key (用于客户端)
SUPABASE_ANON_KEY="your-anon-key"

# Supabase Service Role Key (仅用于服务端)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
